<idea-plugin>
    <id>io.github.mmhelloworld.idrisintellij</id>
    <name>Idris 2 (JVM)</name>
    <vendor url="https://github.com/mmhelloworld">mmhelloworld</vendor>
    <description><![CDATA[
        IDE support for <a href="https://www.idris-lang.org/">Idris 2</a>, talking directly to the
        compiler's IDE-mode protocol — works great with the
        <a href="https://github.com/mmhelloworld/idris-jvm">JVM backend</a> (and any idris2 build).
        <ul>
            <li>Syntax highlighting (lexical + compiler semantic highlighting)</li>
            <li>Compiler diagnostics as you save</li>
            <li>Type-at-point hover documentation and go-to-definition</li>
            <li>Type-driven interactive editing: case split, add clause, proof search,
                generate definition, make lemma, make case, make with (Alt-Enter)</li>
            <li>Integrated REPL tool window</li>
        </ul>
        Configure the idris2 executable under Settings | Languages &amp; Frameworks | Idris 2.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="Idris" language="Idris" extensions="idr;ipkg"
                  implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisFileType"
                  fieldName="INSTANCE"/>
        <fileType name="Literate Idris" language="IdrisLiterate" extensions="lidr"
                  implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisLiterateFileType"
                  fieldName="INSTANCE"/>
        <lang.parserDefinition language="Idris"
                               implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisParserDefinition"/>
        <lang.parserDefinition language="IdrisLiterate"
                               implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisLiterateParserDefinition"/>
        <lang.syntaxHighlighterFactory language="Idris"
                                       implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisSyntaxHighlighterFactory"/>
        <lang.syntaxHighlighterFactory language="IdrisLiterate"
                                       implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisLiterateSyntaxHighlighterFactory"/>
        <colorSettingsPage implementation="io.github.mmhelloworld.idrisintellij.lang.IdrisColorSettingsPage"/>
        <lang.commenter language="Idris"
                        implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisCommenter"/>
        <lang.braceMatcher language="Idris"
                           implementationClass="io.github.mmhelloworld.idrisintellij.lang.IdrisBraceMatcher"/>

        <externalAnnotator language="Idris"
                           implementationClass="io.github.mmhelloworld.idrisintellij.annotator.IdrisExternalAnnotator"/>

        <lang.documentationProvider language="Idris"
                                    implementationClass="io.github.mmhelloworld.idrisintellij.navigation.IdrisDocumentationProvider"/>
        <gotoDeclarationHandler
            implementation="io.github.mmhelloworld.idrisintellij.navigation.IdrisGotoDeclarationHandler"/>
        <completion.contributor language="Idris"
                                implementationClass="io.github.mmhelloworld.idrisintellij.navigation.IdrisCompletionContributor"/>

        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.CaseSplitIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.AddClauseIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.ProofSearchIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.GenerateDefIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.MakeLemmaIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.MakeCaseIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.MakeWithIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.IntroIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.RefineIntention</className>
            <category>Idris</category>
        </intentionAction>
        <intentionAction>
            <language>Idris</language>
            <className>io.github.mmhelloworld.idrisintellij.intentions.NextSolutionIntention</className>
            <category>Idris</category>
        </intentionAction>

        <toolWindow id="Idris REPL" anchor="bottom" canCloseContents="false"
                    factoryClass="io.github.mmhelloworld.idrisintellij.repl.IdrisReplToolWindowFactory"
                    icon="io.github.mmhelloworld.idrisintellij.lang.IdrisIcons.FILE"/>
        <toolWindow id="Idris Holes" anchor="right" canCloseContents="false"
                    factoryClass="io.github.mmhelloworld.idrisintellij.repl.IdrisHolesToolWindowFactory"
                    icon="io.github.mmhelloworld.idrisintellij.lang.IdrisIcons.FILE"/>

        <applicationConfigurable groupId="language" id="io.github.mmhelloworld.idrisintellij.settings"
                                 displayName="Idris 2"
                                 instance="io.github.mmhelloworld.idrisintellij.settings.IdrisConfigurable"/>

        <notificationGroup id="Idris" displayType="BALLOON"/>
    </extensions>
</idea-plugin>
